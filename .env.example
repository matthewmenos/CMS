# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development

# Admin credentials (seeded on first run — change immediately after deploy)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@copagonaahanta.org
ADMIN_PASSWORD=Admin@1234

# Church identity
CHURCH_NAME=COP Agona Ahanta
CHURCH_SLUG=cop-agona-ahanta

# Cloudflare R2  (leave blank to run in local-only mode without cloud storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_MEDIA=cop-agona-ahanta-media
R2_BUCKET_DB=cop-agona-ahanta-db
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
